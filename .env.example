# Daikin Developer Portal credentials
# https://developer.cloud.daikineurope.com/
DAIKIN_CLIENT_ID=
DAIKIN_CLIENT_SECRET=

# Single redirect URI registered in Daikin portal (WITHOUT http://).
# Use the production Cloud Run host — it acts as OAuth proxy for dev + prod:
#   daikin-dashboard-xyz.europe-west1.run.app/api/auth/callback
DAIKIN_REDIRECT_URI=daikin-dashboard-ybxsfxru2a-ew.a.run.app/api/auth/callback

# Where this instance receives the code after the proxy redirect (optional).
# Local dev default: http://localhost:3000/api/auth/callback
# Production: set DAIKIN_PUBLIC_URL or leave unset (derived from request host).
# DAIKIN_OAUTH_RETURN_URI=http://localhost:3000/api/auth/callback

# Public HTTPS origin for production (no trailing slash). Used for OAuth return URI
# and proxy allowlist when running on Cloud Run.
# DAIKIN_PUBLIC_URL=https://daikin-dashboard-ybxsfxru2a-ew.a.run.app

# Extra allowed OAuth return targets for the proxy (comma-separated full URLs).
# DAIKIN_OAUTH_ALLOWED_RETURN_URIS=http://localhost:3000/api/auth/callback

# Optional: OAuth tokens as JSON (for Cloud Run — mount from Secret Manager)
# DAIKIN_TOKENS_JSON={"access_token":"...","refresh_token":"..."}

# Optional: writable token cache path (default: .data/tokens.json)
# DAIKIN_TOKEN_FILE=.data/tokens.json

# Optional: lock dashboard to one site (UUID from /api/sites)
# DAIKIN_SITE_ID=

# Optional: custom room labels keyed by gateway device id (JSON)
# DAIKIN_ROOM_LABELS={"uuid-1":"Obývák","uuid-2":"Ložnice"}

# Optional: protect public deployment (HTTP Basic or Bearer)
# DASHBOARD_ACCESS_TOKEN=
