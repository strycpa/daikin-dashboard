# Daikin Developer Portal credentials
# https://developer.cloud.daikineurope.com/
DAIKIN_CLIENT_ID=
DAIKIN_CLIENT_SECRET=

# Redirect URI registered in Daikin portal (https://, production Cloud Run callback).
DAIKIN_REDIRECT_URI=https://daikin-dashboard-ybxsfxru2a-ew.a.run.app/api/auth/callback

# Public app URL — required on Cloud Run (redirects, OAuth return on prod).
DAIKIN_PUBLIC_URL=https://daikin-dashboard-ybxsfxru2a-ew.a.run.app

# Household identifier for Firestore token storage (default: Strejdomov).
# DAIKIN_HOUSEHOLD_ID=Strejdomov

# Token storage: file (local dev) or firestore (Cloud Run — auto when GCP project is set).
# DAIKIN_TOKEN_BACKEND=file

# GCP project for Firestore (auto on Cloud Run via GOOGLE_CLOUD_PROJECT).
# GCP_PROJECT_ID=daikin-dashboard-prod

# Optional: OAuth tokens as JSON — legacy bootstrap / one-time migration to Firestore
# DAIKIN_TOKENS_JSON={"access_token":"...","refresh_token":"..."}

# Optional: writable token cache path for file backend (default: .data/tokens.json)
# DAIKIN_TOKEN_FILE=.data/tokens.json

# Optional: lock dashboard to one site (UUID from /api/sites)
# DAIKIN_SITE_ID=

# Optional: custom room labels keyed by gateway device id (JSON)
# DAIKIN_ROOM_LABELS={"uuid-1":"Obývák","uuid-2":"Ložnice"}

# Optional: protect public deployment (HTTP Basic or Bearer)
# DASHBOARD_ACCESS_TOKEN=
